---
import type { Lang } from "@/i18n";
import SEO from "@/components/SEO.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

interface SeoProps {
  title: string;
  description: string;
  image?: string;
  canonical: string;
  jsonLd?: Record<string, unknown>;
}

interface Props {
  seo: SeoProps;
  lang: Lang;
  alternateUrl: string;
  isLanding?: boolean;
}

const { seo, lang, alternateUrl, isLanding = false } = Astro.props;
const currentPath = Astro.url.pathname;
const htmlLang = lang === "pt" ? "pt-BR" : "en";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- FWOT prevention: apply theme before paint -->
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <SEO {...seo} lang={lang} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header lang={lang} currentPath={currentPath} alternateUrl={alternateUrl} isLanding={isLanding} />

    <main class="flex-1">
      <slot />
    </main>

    <Footer lang={lang} />

    <!-- Cursor FX: sun (light) / moon+stars (dark) -->
    <div id="cursor-fx" aria-hidden="true">
      <svg id="cursor-sun" xmlns="http://www.w3.org/2000/svg" viewBox="-18 -18 36 36" width="36" height="36" fill="none">
        <circle cx="0" cy="0" r="4" fill="currentColor"/>
        <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6,0 9,-2 12,1.5 15,0"/>
          <g transform="rotate(45)"><polyline points="6,0 9,-2 12,1.5 15,0"/></g>
          <g transform="rotate(90)"><polyline points="6,0 9,-2 12,1.5 15,0"/></g>
          <g transform="rotate(135)"><polyline points="6,0 9,-2 12,1.5 15,0"/></g>
          <g transform="rotate(180)"><polyline points="6,0 9,-2 12,1.5 15,0"/></g>
          <g transform="rotate(225)"><polyline points="6,0 9,-2 12,1.5 15,0"/></g>
          <g transform="rotate(270)"><polyline points="6,0 9,-2 12,1.5 15,0"/></g>
          <g transform="rotate(315)"><polyline points="6,0 9,-2 12,1.5 15,0"/></g>
        </g>
      </svg>
      <svg id="cursor-moon" xmlns="http://www.w3.org/2000/svg" viewBox="-18 -18 36 36" width="36" height="36">
        <defs>
          <mask id="cursor-moon-mask">
            <rect x="-18" y="-18" width="36" height="36" fill="white"/>
            <circle cx="3" cy="-2" r="5" fill="black"/>
          </mask>
        </defs>
        <circle cx="0" cy="0" r="6" fill="currentColor" mask="url(#cursor-moon-mask)"/>
        <g fill="currentColor">
          <path d="M13,-2 L13.28,-0.28 L15,0 L13.28,0.28 L13,2 L12.72,0.28 L11,0 L12.72,-0.28 Z"/>
          <g transform="rotate(60)"><path d="M13,-2 L13.28,-0.28 L15,0 L13.28,0.28 L13,2 L12.72,0.28 L11,0 L12.72,-0.28 Z"/></g>
          <g transform="rotate(120)"><path d="M13,-2 L13.28,-0.28 L15,0 L13.28,0.28 L13,2 L12.72,0.28 L11,0 L12.72,-0.28 Z"/></g>
          <g transform="rotate(180)"><path d="M13,-2 L13.28,-0.28 L15,0 L13.28,0.28 L13,2 L12.72,0.28 L11,0 L12.72,-0.28 Z"/></g>
          <g transform="rotate(240)"><path d="M13,-2 L13.28,-0.28 L15,0 L13.28,0.28 L13,2 L12.72,0.28 L11,0 L12.72,-0.28 Z"/></g>
          <g transform="rotate(300)"><path d="M13,-2 L13.28,-0.28 L15,0 L13.28,0.28 L13,2 L12.72,0.28 L11,0 L12.72,-0.28 Z"/></g>
        </g>
      </svg>
    </div>

    <script>
      import gsap from "gsap";
      import ScrollTrigger from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: no-preference)", () => {
        // Hero fade-in
        gsap.utils.toArray<HTMLElement>("[data-animate='hero']").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
          );
        });

        // Landing header — hidden until scroll threshold, then slides in
        const HEADER_SCROLL_THRESHOLD = 300;
        const landingHeader = document.querySelector<HTMLElement>("[data-landing-header]");
        if (landingHeader) {
          ScrollTrigger.create({
            start: HEADER_SCROLL_THRESHOLD,
            onEnter: () => {
              gsap.to(landingHeader, {
                opacity: 1,
                y: 0,
                duration: 0.5,
                ease: "power2.out",
                onStart: () => {
                  landingHeader.style.pointerEvents = "auto";
                },
              });
            },
            onLeaveBack: () => {
              gsap.to(landingHeader, {
                opacity: 0,
                y: "-100%",
                duration: 0.4,
                ease: "power2.in",
                onComplete: () => {
                  landingHeader.style.pointerEvents = "none";
                },
              });
            },
          });
        }

        // Hero waves — GSAP parallax + organic motion + mouse interaction
        const heroSection = document.querySelector<HTMLElement>("[data-animate='hero']");
        const oceanContainer = document.querySelector<HTMLElement>("[data-animate='hero-ocean']");

        if (heroSection && oceanContainer) {
          const waves = oceanContainer.querySelectorAll<SVGPathElement>(".hero-wave");

          // ── Speed multiplier (increase to speed up all waves, decrease to slow) ──
          const SPEED_MULTIPLIER = 2;

          // Traveling wave — truly seamless infinite horizontal scroll.
          // Each path tiles exactly at its wavelength, and the modifier keeps x
          // permanently in [−wavelength, 0] without ever resetting visibly.
          // Base durations in seconds (before multiplier): blend=22, wave1=18, wave2=12, wave3=8
          const baseWaveSpeeds = [22, 18, 12, 8];
          const CYCLES = 3000; // effectively infinite within any browser session
          waves.forEach((wave, i) => {
            const wavelength = parseFloat(wave.dataset.wavelength || "360");
            const cycleDur = (baseWaveSpeeds[i] || 12) / SPEED_MULTIPLIER;
            gsap.to(wave, {
              x: -(wavelength * CYCLES),
              duration: cycleDur * CYCLES,
              ease: "none",
              modifiers: {
                // Wrap x into [−wavelength, 0] — jump is invisible because paths tile
                x: (val: number) => (val % -wavelength) + "px",
              },
            });
          });

          // Gentle vertical bob — each layer sways independently
          const baseBobConfigs = [
            { amount: 8, dur: 6 },
            { amount: 12, dur: 5 },
            { amount: 18, dur: 4.2 },
            { amount: 24, dur: 3.4 },
          ];
          waves.forEach((wave, i) => {
            const cfg = baseBobConfigs[i] || { amount: 15, dur: 4 };
            gsap.to(wave, {
              y: cfg.amount,
              duration: cfg.dur / SPEED_MULTIPLIER,
              ease: "sine.inOut",
              repeat: -1,
              yoyo: true,
              delay: i * 0.4,
            });
          });

          // Scroll parallax — each wave moves at its own rate
          waves.forEach((wave) => {
            const speed = parseFloat(wave.dataset.parallaxSpeed || "0.5");
            gsap.to(wave, {
              yPercent: speed * 30,
              ease: "none",
              scrollTrigger: {
                trigger: heroSection,
                start: "top top",
                end: "bottom top",
                scrub: true,
              },
            });
          });

          // Mouse interaction — pull entire ocean toward cursor
          const oceanX = gsap.quickTo(oceanContainer, "x", { duration: 1, ease: "power3.out" });
          const oceanY = gsap.quickTo(oceanContainer, "y", { duration: 1, ease: "power3.out" });

          const heroContainer = heroSection.querySelector<HTMLElement>(".gsap-target");
          if (heroContainer) {
            heroContainer.addEventListener("mousemove", (e) => {
              const rect = heroContainer.getBoundingClientRect();
              const xNorm = (e.clientX - rect.left) / rect.width - 0.5;
              const yNorm = (e.clientY - rect.top) / rect.height - 0.5;

              oceanX(xNorm * 30);
              oceanY(yNorm * 15);
            });

            heroContainer.addEventListener("mouseleave", () => {
              oceanX(0);
              oceanY(0);
            });
          }
        }

        // Footprints — appear step by step (walking pace), then wash away and repeat
        if (heroSection) {
          const footprints = Array.from(
            heroSection.querySelectorAll<SVGElement>(".hero-footprint"),
          );
          if (footprints.length > 0) {
            gsap.set(footprints, { opacity: 0 });

            const fpTl = gsap.timeline({ repeat: -1, repeatDelay: 1 });

            // Each print appears 0.45s after the previous — leisurely beach walk pace
            footprints.forEach((fp, i) => {
              fpTl.to(fp, { opacity: 1, duration: 0.18, ease: "power1.out" }, i * 0.45);
            });

            // Hold 2.5s, then fade out in reverse — like tide washing prints away
            fpTl.to(
              [...footprints].reverse(),
              { opacity: 0, duration: 0.7, stagger: 0.1, ease: "power1.in" },
              "+=2.5",
            );
          }
        }

        // Editorial stack — smooth scrubbed reveal; once:true keeps final state on scroll-back
        gsap.utils.toArray<HTMLElement>("[data-animate='editorial-pin']").forEach((editorialPin) => {
          const editorialText  = editorialPin.querySelector<HTMLElement>("[data-animate='editorial-text']");
          const editorialStack = editorialPin.querySelector<HTMLElement>("[data-animate='editorial-stack']");
          const stackCards     = gsap.utils.toArray<HTMLElement>(
            editorialPin.querySelectorAll(".editorial-card"),
          );

          if (!editorialStack || stackCards.length === 0) return;

          const rotations    = [-3, 2.5, -1.75, 3.25, -2.25];
          const stackOffsets = [
            { x: 0,   y: 0   },
            { x: 10,  y: -8  },
            { x: -10, y: 6   },
            { x: 7,   y: 10  },
            { x: -6,  y: -10 },
          ];

          stackCards.forEach((card, i) => {
            gsap.set(card, {
              opacity:  i === 0 ? 1 : 0,
              x:        i === 0 ? stackOffsets[0].x : 40,
              y:        i === 0 ? stackOffsets[0].y : 90,
              scale:    i === 0 ? 1 : 0.92,
              rotation: i === 0 ? rotations[0] : 8,
            });
          });
          if (editorialText) gsap.set(editorialText, { opacity: 0, x: -48 });
          gsap.set(editorialStack, { opacity: 0, x: 48 });

          const tl = gsap.timeline({
            scrollTrigger: {
              trigger:             editorialPin,
              start:               "center center",
              end:                 "+=1220",
              pin:                 true,
              pinSpacing:          true,
              anticipatePin:       1,
              scrub:               1,
              invalidateOnRefresh: true,
            },
          });

          if (editorialText) {
            tl.to(editorialText, { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" }, 0);
          }
          tl.to(editorialStack, { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" }, 0.08);

          stackCards.slice(1).forEach((card, i) => {
            const cardIndex = i + 1;
            tl.to(
              card,
              {
                opacity:  1,
                x:        stackOffsets[cardIndex]?.x ?? 0,
                y:        stackOffsets[cardIndex]?.y ?? 0,
                scale:    1,
                rotation: rotations[cardIndex] ?? 0,
                duration: 1.1,
                ease:     "power3.out",
              },
              1.0 + i * 2,
            );
          });
        });

        // Card stagger reveal
        const cards = gsap.utils.toArray<HTMLElement>("[data-animate='card']");
        cards.forEach((el, i) => {
          gsap.fromTo(
            el,
            { opacity: 0, y: 20 },
            {
              opacity: 1,
              y: 0,
              duration: 0.5,
              delay: i * 0.1,
              scrollTrigger: {
                trigger: el,
                start: "top 85%",
              },
            },
          );
        });

        // Mosaic row slide-in
        gsap.utils.toArray<HTMLElement>("[data-animate='mosaic-row']").forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: -30 },
            {
              opacity: 1,
              x: 0,
              duration: 0.6,
              scrollTrigger: {
                trigger: el,
                start: "top 80%",
              },
            },
          );
        });

        // Cover parallax
        gsap.utils.toArray<HTMLElement>("[data-animate='cover']").forEach((el) => {
          gsap.fromTo(
            el,
            { y: 0 },
            {
              y: 60,
              scrollTrigger: {
                trigger: el,
                start: "top top",
                end: "bottom top",
                scrub: 1,
              },
            },
          );
        });
      });

      // Cursor FX — follow mouse, show sun or moon+stars based on theme
      const cursorFx = document.getElementById("cursor-fx");
      if (cursorFx && window.matchMedia("(hover: hover)").matches) {
        document.addEventListener("mousemove", (e) => {
          cursorFx.style.left = e.clientX + "px";
          cursorFx.style.top = e.clientY + "px";
          cursorFx.style.opacity = "1";
        });
        document.addEventListener("mouseleave", () => {
          cursorFx.style.opacity = "0";
        });
      }
    </script>
  </body>
</html>
