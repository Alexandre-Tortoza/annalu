---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@/i18n";
import { getLocalizedPath } from "@/i18n";

interface Props {
  artwork: CollectionEntry<"artworks">;
  lang: Lang;
}

const { artwork, lang } = Astro.props;
const { data, id } = artwork;

const title = lang === "pt" ? data.titlePt : data.title;
const href = getLocalizedPath(`/artwork/${id}`, lang);
---

<a href={href} class="block group" data-animate="mosaic-row">
  <article class="gsap-target relative">
    <div class="grid grid-cols-12 gap-2">
      {data.mosaic.map((cell) => {
        const img = data.images[cell.imageIndex];
        if (!img) return null;

        return (
          <div
            style={`grid-column: ${cell.colStart} / span ${cell.colSpan}; grid-row: span ${cell.rowSpan ?? 1};`}
            class="overflow-hidden rounded-md"
          >
            <img
              src={img.src}
              alt={img.alt}
              width={Math.round((cell.colSpan / 12) * 1200)}
              height={Math.round((cell.colSpan / 12) * 800)}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
            />
          </div>
        );
      })}
    </div>
    <div class="mt-3 flex items-baseline justify-between">
      <h3 class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
        {title}
      </h3>
      {data.technique && (
        <span class="text-sm text-[var(--color-text-muted)]">{data.technique}</span>
      )}
    </div>
  </article>
</a>
