---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@/i18n";
import { getLocalizedPath } from "@/i18n";

interface Props {
  artwork: CollectionEntry<"artworks">;
  lang: Lang;
}

const { artwork, lang } = Astro.props;
const { data, id } = artwork;

const title = lang === "pt" ? data.titlePt : data.title;
const description = lang === "pt" ? data.descriptionPt : data.description;
const href = getLocalizedPath(`/artwork/${id}`, lang);
---

<article data-animate="card" class="gsap-target group">
  <a href={href} class="block overflow-hidden rounded-lg bg-[var(--color-surface)] transition-shadow hover:shadow-lg">
    <div class="aspect-[4/3] overflow-hidden">
      <img
        src={data.cover.src}
        alt={data.cover.alt}
        width="600"
        height="450"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
    <div class="p-4">
      <h3 class="text-lg font-semibold text-[var(--color-text)]">{title}</h3>
      <p class="mt-1 text-sm text-[var(--color-text-muted)] line-clamp-2">{description}</p>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {data.tags.slice(0, 3).map((tag) => (
          <span class="rounded-full bg-[var(--color-accent-light)] px-2.5 py-0.5 text-xs text-[var(--color-accent)]">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>
</article>
