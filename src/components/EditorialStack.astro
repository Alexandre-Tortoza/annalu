---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@/i18n";
import { useTranslations } from "@/i18n";
import { sortByDate } from "@/lib/artworks";

interface Props {
  artworks: CollectionEntry<"artworks">[];
  lang: Lang;
}

const { artworks, lang } = Astro.props;
const t = useTranslations(lang);
const covers = sortByDate(artworks).slice(0, 3);
---

<section class="mx-auto max-w-6xl px-4 pt-48 pb-48 sm:px-6">
  <div class="grid gap-16 md:grid-cols-2 md:items-center">
    <blockquote class="text-2xl font-light italic text-[var(--color-text)] leading-relaxed font-serif" data-animate="editorial-text">
      &ldquo;{t("editorial.quote")}&rdquo;
    </blockquote>
    <div class="editorial-stack relative aspect-[4/3]" data-animate="editorial-stack">
      {covers.map((artwork, i) => (
        <img
          src={artwork.data.cover.src}
          alt={artwork.data.cover.alt}
          width="600"
          height="450"
          loading="lazy"
          decoding="async"
          class="editorial-card absolute inset-0 h-full w-full rounded-xl object-cover shadow-lg"
          data-stack-i={i}
        />
      ))}
    </div>
  </div>
</section>
