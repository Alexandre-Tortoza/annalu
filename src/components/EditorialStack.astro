---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@/i18n";
import { useTranslations } from "@/i18n";
import { sortByDate } from "@/lib/artworks";

interface Props {
  artworks: CollectionEntry<"artworks">[];
  lang: Lang;
}

const { artworks, lang } = Astro.props;
const t = useTranslations(lang);
const covers = sortByDate(artworks).slice(0, 5);
---

<section class="mx-auto mt-32 mb-32 max-w-6xl px-4 py-64 sm:px-6 md:mt-48 md:mb-48" data-animate="editorial-section">
  <div class="editorial-pin grid gap-16 md:grid-cols-2 md:items-center" data-animate="editorial-pin">
    <blockquote class="text-2xl font-light italic text-[var(--color-text)] leading-relaxed font-serif" data-animate="editorial-text">
      &ldquo;{t("editorial.quote")}&rdquo;
    </blockquote>
    <div class="editorial-stack relative aspect-[4/3]" data-animate="editorial-stack">
      {covers.map((artwork, i) => (
        <img
          src={artwork.data.cover.src}
          alt={artwork.data.cover.alt}
          width="600"
          height="450"
          loading="lazy"
          decoding="async"
          class={`editorial-card absolute inset-0 h-full w-full rounded-xl object-cover shadow-lg ${i === 0 ? "" : "opacity-0"}`}
          data-stack-i={i}
          style={`z-index: ${i + 1}`}
        />
      ))}
    </div>
  </div>
</section>
