---
import type { Lang } from "@/i18n";
import { getAlternateUrl } from "@/i18n";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical: string;
  jsonLd?: Record<string, unknown>;
  lang: Lang;
}

const { title, description, image, canonical, jsonLd, lang } = Astro.props;

const site = Astro.site?.origin ?? "https://annalu.art";
const fullTitle = `${title} | AnnaLu`;
const ogImage = image ? `${site}${image}` : undefined;
const currentPath = new URL(canonical).pathname;
const alternateLang = lang === "pt" ? "en" : "pt";
const alternateHref = `${site}${getAlternateUrl(currentPath, alternateLang)}`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />

<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang={lang === "pt" ? "pt-BR" : "en"} href={canonical} />
<link rel="alternate" hreflang={alternateLang === "pt" ? "pt-BR" : "en"} href={alternateHref} />
<link rel="alternate" hreflang="x-default" href={`${site}/`} />

<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="AnnaLu" />
{ogImage && <meta property="og:image" content={ogImage} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
