---
import type { Lang } from "@/i18n";
import { useTranslations } from "@/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="border-t border-[var(--color-footer-border)] bg-[var(--color-footer-bg)] text-[var(--color-footer-text)]">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 py-8 sm:flex-row sm:justify-between sm:px-6">
    <div class="flex gap-4">
      <a
        href="#"
        class="text-sm text-[var(--color-footer-text-muted)] hover:text-[var(--color-footer-text)] transition-colors"
        aria-label="Instagram"
      >
        Instagram
      </a>
      <a
        href="#"
        class="text-sm text-[var(--color-footer-text-muted)] hover:text-[var(--color-footer-text)] transition-colors"
        aria-label="Behance"
      >
        Behance
      </a>
    </div>
    <p class="text-sm text-[var(--color-footer-text-muted)]">
      {t("footer.copyright")}
    </p>
  </div>
</footer>
