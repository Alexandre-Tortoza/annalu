---
import type { Lang } from "@/i18n";
import { useTranslations, getLocalizedPath } from "@/i18n";
import ThemeToggle from "./ThemeToggle.astro";
import LanguagePicker from "./LanguagePicker.astro";

interface Props {
  lang: Lang;
  currentPath: string;
  alternateUrl: string;
  isLanding?: boolean;
}

const { lang, currentPath, alternateUrl, isLanding = false } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { label: t("nav.home"), href: getLocalizedPath("/", lang) },
  { label: t("nav.gallery"), href: getLocalizedPath("/galeria", lang) },
];

function isActive(href: string): boolean {
  const normalized = currentPath.endsWith("/") ? currentPath.slice(0, -1) : currentPath;
  const normalizedHref = href.endsWith("/") ? href.slice(0, -1) : href;
  if (normalizedHref === "" || normalizedHref === "/en") {
    return normalized === "" || normalized === "/" || normalized === "/en";
  }
  return normalized === normalizedHref;
}
---

<header
  class:list={[
    "top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-surface)]/95 backdrop-blur-sm shadow-black/01 shadow-lg",
    isLanding ? "fixed inset-x-0 header-landing" : "sticky",
  ]}
  data-landing-header={isLanding ? "" : undefined}
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-3 py-2 sm:px-6 sm:py-3 lg:px-8">
    <a
      href={getLocalizedPath("/", lang)}
      class="block shrink-0 transition-opacity hover:opacity-80"
      aria-label={t("nav.home")}
    >
      <img
        src="/logo.png"
        alt="Annalu"
        width="280"
        height="80"
        class="relative top-[3px] -rotate-20 h-12 w-auto sm:h-14 md:h-16 lg:h-20 xl:h-24"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-4 md:flex lg:gap-6" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            "font-serif text-sm transition-colors lg:text-base",
            isActive(href)
              ? "font-semibold text-[var(--color-accent)]"
              : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
          ]}
          aria-current={isActive(href) ? "page" : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-1.5 md:flex lg:gap-2">
      <LanguagePicker lang={lang} alternateUrl={alternateUrl} />
      <ThemeToggle lang={lang} />
    </div>

    <!-- Mobile menu -->
    <details class="group md:hidden">
      <summary
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg cursor-pointer
               sm:h-10 sm:w-10
               hover:bg-[var(--color-surface-hover)] list-none
                focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
        aria-label={t("aria.openMenu")}
      >
        <svg
          class="h-5 w-5 group-open:hidden"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg
          class="hidden h-5 w-5 group-open:block"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </summary>
      <nav
        class="absolute left-0 right-0 top-full border-b border-[var(--color-border)]
               bg-[var(--color-surface)] px-4 py-4 sm:px-6"
        aria-label="Mobile navigation"
      >
        <div class="flex flex-col gap-4">
          {navLinks.map(({ label, href }) => (
            <a
              href={href}
              class:list={[
                "font-serif text-base transition-colors",
                isActive(href)
                  ? "font-semibold text-[var(--color-accent)]"
                  : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
              ]}
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          ))}
          <div class="flex items-center gap-3 pt-2 border-t border-[var(--color-border)]">
            <LanguagePicker lang={lang} alternateUrl={alternateUrl} />
            <ThemeToggle lang={lang} />
          </div>
        </div>
      </nav>
    </details>
  </div>
</header>

<style>
  .header-landing {
    opacity: 0;
    transform: translateY(-100%);
    pointer-events: none;
  }
</style>
