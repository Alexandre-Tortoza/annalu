---
import { getCollection } from "astro:content";
import type { Lang } from "@/i18n";
import { useTranslations } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MosaicRow from "@/components/MosaicRow.astro";
import { sortByDate } from "@/lib/artworks";

const lang: Lang = "pt";
const t = useTranslations(lang);
const alternateUrl = "/en/gallery";
const site = Astro.site?.origin ?? "https://annalu.art";

const artworks = sortByDate(await getCollection("artworks"));

const seo = {
  title: t("gallery.title"),
  description: t("gallery.description"),
  canonical: `${site}/galeria`,
};
---

<BaseLayout seo={seo} lang={lang} alternateUrl={alternateUrl}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-[var(--color-text)] sm:text-4xl">
        {t("gallery.title")}
      </h1>
      <p class="mt-3 text-[var(--color-text-muted)]">
        {t("gallery.description")}
      </p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">
        {artworks.length} {t("gallery.count")}
      </p>
    </div>

    <!-- TODO Phase 2: tag/technique/year filters -->

    <div class="flex flex-col gap-12">
      {artworks.map((artwork) => (
        <MosaicRow artwork={artwork} lang={lang} />
      ))}
    </div>
  </section>
</BaseLayout>
