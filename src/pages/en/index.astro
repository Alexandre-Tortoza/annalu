---
import { getCollection } from "astro:content";
import type { Lang } from "@/i18n";
import { useTranslations } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArtworkCard from "@/components/ArtworkCard.astro";
import EditorialStack from "@/components/EditorialStack.astro";
import Hero from "@/components/Hero.astro";
import { sortByDate } from "@/lib/artworks";

const lang: Lang = "en";
const t = useTranslations(lang);
const alternateUrl = "/";
const site = Astro.site?.origin ?? "https://annalu.art";

const allArtworks = await getCollection("artworks");
const latestArtworks = sortByDate(allArtworks).slice(0, 3);

const seo = {
  title: t("hero.title"),
  description: t("hero.subtitle"),
  canonical: `${site}/en/`,
};
---

<BaseLayout seo={seo} lang={lang} alternateUrl={alternateUrl} isLanding>
  <Hero lang={lang} />

  <EditorialStack artworks={allArtworks} lang={lang} />

  <!-- Latest works -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold text-[var(--color-text)] sm:text-3xl font-serif">
      {t("section.latest")}
    </h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestArtworks.map((artwork) => (
        <ArtworkCard artwork={artwork} lang={lang} />
      ))}
    </div>
  </section>

  <!-- About the artist -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-8 md:grid-cols-2 md:items-center">
      <div class="overflow-hidden rounded-xl">
        <img
          src="/images/author-photo.jpg"
          alt="Portrait of the artist"
          width="500"
          height="600"
          loading="lazy"
          decoding="async"
          class="w-full object-cover"
        />
      </div>
      <div>
        <h2 class="text-2xl font-bold text-[var(--color-text)] sm:text-3xl font-serif">
          {t("section.about")}
        </h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          {t("section.about.text")}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
