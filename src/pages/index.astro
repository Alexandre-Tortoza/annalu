---
import { getCollection } from "astro:content";
import type { Lang } from "@/i18n";
import { useTranslations } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArtworkCard from "@/components/ArtworkCard.astro";

const lang: Lang = "pt";
const t = useTranslations(lang);
const alternateUrl = "/en/";
const site = Astro.site?.origin ?? "https://annalu.art";

const allArtworks = await getCollection("artworks");
const latestArtworks = allArtworks
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const seo = {
  title: t("hero.title"),
  description: t("hero.subtitle"),
  canonical: `${site}/`,
};
---

<BaseLayout seo={seo} lang={lang} alternateUrl={alternateUrl}>
  <!-- Hero -->
  <section
    data-animate="hero"
    class="gsap-target mx-auto max-w-6xl px-4 py-20 text-center sm:px-6 sm:py-32"
  >
    <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text)] sm:text-5xl md:text-6xl font-serif">
      {t("hero.title")}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-text-muted)]">
      {t("hero.subtitle")}
    </p>
    <a
      href="/galeria"
      class="mt-8 inline-block rounded-lg bg-[var(--color-accent)] px-6 py-3 text-sm font-medium text-white
             transition-colors hover:bg-[var(--color-accent-hover)]
             focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
    >
      {t("hero.cta")}
    </a>
  </section>

  <!-- Editorial grid -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-8 md:grid-cols-2 md:items-center">
      <blockquote class="text-2xl font-light italic text-[var(--color-text)] leading-relaxed font-serif">
        &ldquo;{t("editorial.quote")}&rdquo;
      </blockquote>
      <div class="overflow-hidden rounded-xl">
        <img
          src="/images/editorial-photo.jpg"
          alt="Editorial artwork composition"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
          class="w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Latest works -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold text-[var(--color-text)] sm:text-3xl">
      {t("section.latest")}
    </h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestArtworks.map((artwork) => (
        <ArtworkCard artwork={artwork} lang={lang} />
      ))}
    </div>
  </section>

  <!-- About the artist -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-8 md:grid-cols-2 md:items-center">
      <div class="overflow-hidden rounded-xl">
        <img
          src="/images/author-photo.jpg"
          alt="Portrait of the artist"
          width="500"
          height="600"
          loading="lazy"
          decoding="async"
          class="w-full object-cover"
        />
      </div>
      <div>
        <h2 class="text-2xl font-bold text-[var(--color-text)] sm:text-3xl">
          {t("section.about")}
        </h2>
        <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
          {t("section.about.text")}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
