---
import { getCollection } from "astro:content";
import type { Lang } from "@/i18n";
import { getLocalizedPath } from "@/i18n";
import { useTranslations } from "@/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialStack from "@/components/EditorialStack.astro";
import Hero from "@/components/Hero.astro";
import AboutArtist from "@/components/AboutArtist.astro";
import { sortByDate } from "@/lib/artworks";

const lang: Lang = "pt";
const t = useTranslations(lang);
const alternateUrl = "/en/";
const site = Astro.site?.origin ?? "https://annalu.art";

const allArtworks = await getCollection("artworks");
const latestArtworks = sortByDate(allArtworks).slice(0, 4);

const seo = {
  title: t("hero.title"),
  description: t("hero.subtitle"),
  canonical: `${site}/`,
};
---

<BaseLayout seo={seo} lang={lang} alternateUrl={alternateUrl} isLanding>
  <Hero lang={lang}/>


  <EditorialStack artworks={allArtworks} lang={lang} />

  <!-- Latest works -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-6 lg:grid-cols-5 lg:auto-rows-[18rem]">
      <div class="flex items-start lg:row-span-2">
        <h2 class="text-2xl font-bold text-[var(--color-text)] sm:text-3xl font-serif lg:max-w-[8ch]">
          {t("section.latest")}
        </h2>
      </div>
      {latestArtworks.map((artwork) => (
        <a
          href={getLocalizedPath(`/artwork/${artwork.id}`, lang)}
          data-animate="card"
          class="gsap-target group block h-72 overflow-hidden rounded-lg bg-[var(--color-surface)] lg:col-span-2 lg:h-full"
          aria-label={artwork.data.titlePt}
        >
          <img
            src={artwork.data.cover.src}
            alt={artwork.data.cover.alt}
            width="600"
            height="450"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </a>
      ))}
    </div>
  </section>

  <AboutArtist lang={lang} />
</BaseLayout>
